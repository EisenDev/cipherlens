# ==============================================================================
# CipherLens Deployment Environment Variables Template (.env)
# Rename this file to '.env' and fill in the values before starting containers.
# ==============================================================================

# Supabase database connection string (Direct connection / transaction pooler string)
# Replace with your actual Supabase PostgreSQL connection URL.
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require"

# Public URL of the backend API (used by frontend built bundle to route requests)
# Replace with your VM IP or Domain: e.g. "http://192.168.1.100:3005"
VITE_API_URL="http://localhost:3005"

# Google Gemini API key for automated AI-generated security disclosures and reports
GEMINI_API_KEY="AIzaSy..."

# JWT cryptographic secrets for session tokens sign-off validation
JWT_SECRET="generate_a_long_random_jwt_secret_signing_key_for_production"
JWT_ACCESS_SECRET="generate_a_long_random_access_token_secret_key_for_production"
JWT_REFRESH_SECRET="generate_a_long_random_refresh_token_secret_key_for_production"
